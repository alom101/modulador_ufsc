   "source": [
    "t = np.linspace(0,2*np.pi, 32)\n",
    "x = (2**7)*(np.sin(t) + 1)\n",
    "x_quantized = np.array(x, dtype=np.uint8)\n",
    "\n",
    "\n",
    "plt.plot(x_quantized, '.')\n",
    "plt.show()\n",
    "\n",
    "for v in x_quantized:\n",
    "    print(v, )\n"
   ]
